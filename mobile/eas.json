{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://language-tutor-silk.vercel.app"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://language-tutor-silk.vercel.app"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "macos-tahoe-26.4-xcode-26.4"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://language-tutor-silk.vercel.app"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "aidanlconnolly@gmail.com",
        "appleTeamId": "RZ9JCVD6GW",
        "ascAppId": "6779423192"
      }
    }
  }
}
